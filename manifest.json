{
  "manifest_version": 2,
  "name": "NANGKEPINSERA",
  "version": "1.0.11",
  "description": "Auto grab data web dan export CSV",

  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  // "permissions": [
  //  "activeTab"
  // ],
  
  "browser_action": {
    "default_title": "GAMAS Viewer",
    "default_popup": "index.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
	
	"web_accessible_resources": [
  "data/DB_PIC_GAMAS.json"
],

  "browser_specific_settings": {
    "gecko": {
      "id": "NANGKEPINSERA@local",
      "strict_min_version": "142.0",

      "data_collection_permissions": {
        "required": ["websiteContent"],

        "collects_personal_data": false,
        "collects_browsing_data": false,
        "collects_health_data": false,
        "collects_financial_data": false,
        "collects_location_data": false,
        "collects_authentication_data": false,
        "collects_communications_data": false,
        "collects_user_activity": false,
        "collects_content": false
      }
    }
  }
}
